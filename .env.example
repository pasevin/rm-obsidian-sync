# ──────────────────────────────────────────────────────────────────────────────
# rm-obsidian-sync — environment configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── rmfakecloud ───────────────────────────────────────────────────────────────

# URL of your rmfakecloud instance as seen by this daemon (usually localhost).
# Do NOT use your public Tailscale/Caddy URL here — that breaks JWT auth.
RMFAKECLOUD_URL=http://localhost:3000

# rmfakecloud account credentials (created via the rmfakecloud web UI).
RMFAKECLOUD_USER=you@example.com
RMFAKECLOUD_PASS=your-rmfakecloud-password

# Absolute path to the rmfakecloud data directory (the Docker bind-mount).
# This is used for direct blob reads (sync15 / Paper Pro protocol).
# Example: /opt/rmfakecloud/data  or  /home/user/rmfakecloud/data
RMFAKECLOUD_DATA_PATH=/opt/rmfakecloud/data

# ── Obsidian vault ────────────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root.
VAULT_PATH=/home/user/vault

# Sub-path inside the vault where reMarkable notes are written.
# A folder will be created here for each synced notebook.
VAULT_RM_ROOT=Inbox/reMarkable

# ── Daemon ────────────────────────────────────────────────────────────────────

# TCP port the sync daemon listens on.
WEBHOOK_PORT=9090

# ── Handwriting Recognition ───────────────────────────────────────────────────

# OpenRouter API key — used for LLM vision HWR (primary, free tier available).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter model for handwriting recognition.
# Default is free and works well for most handwriting styles.
# LLM_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# MyScript iink Cloud keys — optional secondary HWR fallback.
# Register at https://developer.myscript.com/
# MYSCRIPT_APP_KEY=your-app-key
# MYSCRIPT_HMAC_KEY=your-hmac-key
# HWR_LANGUAGE=en_US

# ── PDF conversion (Obsidian → reMarkable) ────────────────────────────────────

# Path to pandoc binary. Defaults to 'pandoc' (PATH lookup).
# Override if using a non-standard install location.
# PANDOC_BIN=/home/user/.local/bin/pandoc

# Path to wkhtmltopdf binary. Defaults to 'wkhtmltopdf' (PATH lookup).
# WKHTMLTOPDF_BIN=/home/user/.local/bin/wkhtmltopdf

# Extra LD_LIBRARY_PATH entry for the statically-linked wkhtmltopdf build.
# Only needed if using the upstream binary from wkhtmltopdf.org.
# WKHTMLTOPDF_LIB_PATH=/home/user/.local/lib

# ── State files (optional overrides) ─────────────────────────────────────────

# AUTH_STATE_FILE=~/.rm-obsidian-sync/auth.json
# SYNC_STATE_FILE=~/.rm-obsidian-sync/state.json
